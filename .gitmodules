[submodule ".registry"]
	path = .registry
	url = https://github.com/r-universe-org/cran-to-git
	branch = HEAD
[submodule "corncob"]
	path = corncob
	url = https://github.com/statdivlab/corncob
[submodule "radEmu"]
	path = radEmu
	url = https://github.com/statdivlab/rademu
[submodule "rigr"]
	path = rigr
	url = https://github.com/statdivlab/rigr
